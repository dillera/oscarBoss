# Copy to .env.local for local dev, or .env.production for production

# Required for subpath reverse proxy deployment
# Set to the subpath nginx is serving the app under, e.g. /oscars
# Leave empty for root deployment (default)
NEXT_PUBLIC_BASE_PATH=/oscars

# Optional: TMDB API key for refreshing nominee images
TMDB_API_KEY=your_tmdb_api_key_here
